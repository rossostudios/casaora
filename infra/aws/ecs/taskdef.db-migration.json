{
  "family": "casaora-rds-sql",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "runtimePlatform": {
    "operatingSystemFamily": "LINUX",
    "cpuArchitecture": "ARM64"
  },
  "executionRoleArn": "arn:aws:iam::341112583495:role/casaora-backend-task-execution-role",
  "taskRoleArn": "arn:aws:iam::341112583495:role/casaora-backend-task-role",
  "containerDefinitions": [
    {
      "name": "pg-migrator",
      "image": "public.ecr.aws/docker/library/postgres:16-alpine",
      "essential": true,
      "command": ["sh", "-lc", "echo ready"],
      "environment": [],
      "secrets": [
        {
          "name": "TARGET_DATABASE_URL",
          "valueFrom": "REPLACE_ME_TARGET_DATABASE_URL_SECRET_ARN"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/casaora-rds-sql",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
